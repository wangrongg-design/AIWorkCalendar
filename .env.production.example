DATABASE_URL=postgresql://workcalendar:change-me@your-rds-postgresql-internal-host:5432/workcalendar?schema=public

REDIS_HOST=your-redis-internal-host
REDIS_PORT=6379
REDIS_PASSWORD=change-me

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
REQUIRE_EMAIL_VERIFICATION=false
CORS_ORIGIN=https://app.example.com

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

API_PORT=3001
NEXT_PUBLIC_API_URL=https://api.example.com
WEB_PORT_BIND=127.0.0.1:3000
API_PORT_BIND=127.0.0.1:3001

BILLING_PAYMENT_MODE=live
PUBLIC_WEB_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MCH_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat-pay-private-key.pem
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_SERIAL_NO=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=/run/secrets/wechat-pay-platform-public-key.pem
WECHAT_PAY_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_NOTIFY_URL=https://api.example.com/billing/payments/wechat/notify
WECHAT_PAY_RETURN_URL=https://app.example.com/org?tab=billing
