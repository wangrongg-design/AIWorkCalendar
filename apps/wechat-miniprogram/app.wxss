page {
  min-height: 100%;
  overflow-x: hidden;
  background: #F6F6F6;
  color: #1A1A1A;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

image {
  box-sizing: border-box;
}

button {
  display: flex;
  max-width: 100%;
  min-width: 0;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 0;
  font-weight: 600;
  text-align: center;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 48rpx 48rpx 56rpx;
  overflow-x: hidden;
}

.surface {
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(60, 64, 67, 0.045);
}

.muted {
  color: #737373;
}

.page-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
  max-width: 100%;
  overflow: hidden;
}

.page-hero > view:first-child {
  min-width: 0;
}

.page-title {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.page-subtitle {
  max-width: 100%;
  margin-top: 8rpx;
  color: #737373;
  font-size: 25rpx;
  line-height: 1.4;
}

.section-title {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-desc {
  max-width: 100%;
  margin-top: 8rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-button {
  height: 88rpx;
  border-radius: 24rpx;
  background: #0B57D0;
  color: #FFFFFF;
  font-size: 29rpx;
  line-height: 88rpx;
}

.secondary-button {
  height: 80rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 24rpx;
  background: #FFFFFF;
  color: #0B57D0;
  font-size: 27rpx;
  line-height: 80rpx;
}

.tertiary-button {
  height: 72rpx;
  border-radius: 20rpx;
  background: transparent;
  color: #737373;
  font-size: 25rpx;
  line-height: 72rpx;
}

.danger-button {
  height: 80rpx;
  border-radius: 24rpx;
  background: #FEF2F2;
  color: #EE3B2B;
  font-size: 27rpx;
  line-height: 80rpx;
}

.primary-button,
.secondary-button,
.tertiary-button,
.danger-button {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  padding: 0 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #737373;
  font-size: 24rpx;
  font-weight: 600;
}

.input,
.textarea {
  width: 100%;
  max-width: 100%;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  background: #F6F6F6;
  color: #1A1A1A;
  font-size: 28rpx;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  line-height: 1.55;
}

.chip {
  display: inline-flex;
  align-items: center;
  max-width: 220rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 18rpx;
  background: #EEF5FF;
  padding: 8rpx 18rpx;
  color: #0B57D0;
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bottom-safe {
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.ios-card {
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(60, 64, 67, 0.045);
}

.ai-action-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  border: 1rpx solid #CCFBF1;
  border-radius: 32rpx;
  background: #ECFDF9;
  padding: 24rpx;
}

.ai-action-icon {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #CCFBF1;
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 900;
}

.ai-action-copy {
  min-width: 0;
  flex: 1 1 0;
}

.ai-action-kicker {
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.ai-generated-disclosure {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  max-width: 100%;
  overflow: hidden;
  border: 1rpx solid #99F6E4;
  border-radius: 16rpx;
  background: #CCFBF1;
  padding: 8rpx 14rpx;
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ai-generated-note {
  margin-top: 10rpx;
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.45;
}

.ai-action-title {
  margin-top: 8rpx;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.38;
}

.ai-action-desc {
  margin-top: 6rpx;
  color: #424242;
  font-size: 24rpx;
  line-height: 1.5;
}

.segmented-control {
  display: grid;
  gap: 8rpx;
  border-radius: 22rpx;
  background: #EDEDED;
  padding: 6rpx;
}

.segmented-item {
  min-width: 0;
  border-radius: 18rpx;
  padding: 16rpx 4rpx;
  color: #737373;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.segmented-item.active {
  background: #FFFFFF;
  color: #0B57D0;
  box-shadow: 0 4rpx 14rpx rgba(60, 64, 67, 0.08);
}

.empty-state {
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 48rpx 28rpx;
  text-align: center;
}

.empty-title {
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 8rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.45;
}
