page {
  min-height: 100%;
  overflow-x: hidden;
  background: #F6F6F6;
  color: #1A1A1A;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

image {
  box-sizing: border-box;
}

button {
  display: flex;
  max-width: 100%;
  min-width: 0;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 0;
  font-weight: 600;
  text-align: center;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  overflow-x: hidden;
}

.surface {
  border: 1rpx solid #E6E6E6;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 14rpx rgba(60, 64, 67, 0.06);
}

.muted {
  color: #737373;
}

.page-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
  max-width: 100%;
  overflow: hidden;
}

.page-hero > view:first-child {
  min-width: 0;
}

.page-title {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.page-subtitle {
  max-width: 100%;
  margin-top: 8rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.4;
}

.section-title {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-desc {
  max-width: 100%;
  margin-top: 8rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-button {
  height: 88rpx;
  border-radius: 44rpx;
  background: #0B57D0;
  color: #FFFFFF;
  font-size: 29rpx;
  line-height: 88rpx;
}

.secondary-button {
  height: 80rpx;
  border-radius: 40rpx;
  background: #EEF5FF;
  color: #0B57D0;
  font-size: 27rpx;
  line-height: 80rpx;
}

.tertiary-button {
  height: 72rpx;
  border-radius: 36rpx;
  background: #F6F6F6;
  color: #424242;
  font-size: 25rpx;
  line-height: 72rpx;
}

.danger-button {
  height: 80rpx;
  border-radius: 40rpx;
  background: #FEF2F2;
  color: #EE3B2B;
  font-size: 27rpx;
  line-height: 80rpx;
}

.primary-button,
.secondary-button,
.tertiary-button,
.danger-button {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  padding: 0 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #737373;
  font-size: 24rpx;
  font-weight: 600;
}

.input,
.textarea {
  width: 100%;
  max-width: 100%;
  border: 1rpx solid transparent;
  border-radius: 20rpx;
  background: #F6F6F6;
  color: #1A1A1A;
  font-size: 28rpx;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  line-height: 1.55;
}

.chip {
  display: inline-flex;
  align-items: center;
  max-width: 220rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 999rpx;
  background: #EEF5FF;
  padding: 8rpx 18rpx;
  color: #0B57D0;
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bottom-safe {
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}
