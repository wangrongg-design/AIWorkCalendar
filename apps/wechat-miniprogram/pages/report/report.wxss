.report-page {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.report-header {
  padding: 4rpx 0 0;
}

.report-greeting {
  color: #1A1A1A;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
  word-break: break-all;
}

.today-status-panel {
  margin-top: 0;
}

.ai-card,
.draft-card {
  margin-top: 0;
}

.chat-list {
  display: flex;
  max-height: 360rpx;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
  overflow: auto;
}

.chat-message {
  max-width: 92%;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  line-height: 1.55;
  overflow-wrap: break-word;
  word-break: break-all;
}

.chat-message.assistant {
  align-self: flex-start;
  background: #F6F6F6;
  color: #737373;
}

.chat-message.user {
  align-self: flex-end;
  background: #EEF5FF;
  color: #1A1A1A;
}

.chat-input {
  width: 100%;
  min-height: 132rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #F6F6F6;
  padding: 20rpx 22rpx;
  color: #1A1A1A;
  font-size: 27rpx;
  line-height: 1.5;
}

.chat-actions {
  margin-top: 20rpx;
}

.send-ai-button {
  background: #0B57D0;
  color: #FFFFFF;
}

.editor-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.editor-stack .field {
  margin-top: 0;
}

.picker-value {
  display: flex;
  height: 88rpx;
  align-items: center;
  max-width: 100%;
  overflow: hidden;
  border-radius: 16rpx;
  background: #F6F6F6;
  padding: 0 24rpx;
  color: #1A1A1A;
  font-size: 28rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.textarea {
  min-height: 264rpx;
}

.report-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
