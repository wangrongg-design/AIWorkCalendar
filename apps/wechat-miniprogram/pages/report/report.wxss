.report-page {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.report-brief-header {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 4rpx 0 0;
}

.report-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.report-title-copy {
  min-width: 0;
  flex: 1 1 0;
}

.date-pill {
  flex-shrink: 0;
  border-radius: 28rpx;
  background: #EEF5FF;
  padding: 12rpx 18rpx;
  color: #0B57D0;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.2;
}

.step-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.step-pill {
  display: flex;
  min-width: 0;
  min-height: 68rpx;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 34rpx;
  background: #FFFFFF;
  color: #737373;
  font-size: 24rpx;
  font-weight: 800;
}

.step-pill.active {
  border-color: rgba(11, 87, 208, 0.22);
  background: #EEF5FF;
  color: #0B57D0;
}

.step-pill.recording {
  border-color: rgba(15, 118, 110, 0.22);
  background: #ECFDF9;
  color: #0F766E;
}

.step-pill.success {
  border-color: rgba(22, 163, 74, 0.22);
  background: #F0FDF4;
  color: #16A34A;
}

.step-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 28rpx;
}

.text-cursor::before {
  position: absolute;
  left: 12rpx;
  top: 3rpx;
  width: 4rpx;
  height: 22rpx;
  border-radius: 4rpx;
  background: currentColor;
  content: "";
}

.check-seal::before {
  position: absolute;
  left: 6rpx;
  top: 7rpx;
  width: 16rpx;
  height: 10rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  content: "";
  transform: rotate(-45deg);
}

.composer-card,
.draft-card {
  margin-top: 0;
}

.composer-head,
.draft-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.composer-icon,
.draft-icon {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 76rpx;
  border-radius: 24rpx;
  background: #ECFDF9;
  color: #0F766E;
}

.composer-icon::before {
  position: absolute;
  left: 24rpx;
  top: 18rpx;
  width: 28rpx;
  height: 28rpx;
  border: 5rpx solid currentColor;
  border-radius: 50%;
  content: "";
}

.composer-icon::after {
  position: absolute;
  right: 18rpx;
  top: 13rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: -25rpx 34rpx 0 -2rpx currentColor;
  content: "";
}

.draft-icon {
  background: #EEF5FF;
  color: #0B57D0;
}

.draft-icon::before {
  position: absolute;
  left: 22rpx;
  top: 16rpx;
  width: 32rpx;
  height: 42rpx;
  border: 5rpx solid currentColor;
  border-radius: 6rpx;
  content: "";
}

.draft-icon::after {
  position: absolute;
  left: 30rpx;
  top: 31rpx;
  width: 17rpx;
  height: 5rpx;
  border-radius: 5rpx;
  background: currentColor;
  box-shadow: 0 12rpx 0 currentColor;
  content: "";
}

.hint-chip-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.hint-chip {
  min-height: 64rpx;
  border-radius: 32rpx;
  background: #F6F6F6;
  color: #737373;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
}

.chat-list {
  display: flex;
  max-height: 360rpx;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
  overflow: auto;
}

.chat-message {
  max-width: 92%;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  line-height: 1.55;
  overflow-wrap: break-word;
  word-break: break-all;
}

.chat-message.assistant {
  align-self: flex-start;
  background: #F6F6F6;
  color: #737373;
}

.chat-message.user {
  align-self: flex-end;
  background: #EEF5FF;
  color: #1A1A1A;
}

.voice-input-box {
  position: relative;
  margin-top: 24rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #F6F6F6;
  padding: 0;
}

.voice-input-box.recording {
  border-color: #CCFBF1;
  background: #ECFDF9;
}

.chat-input {
  width: 100%;
  min-height: 300rpx;
  max-height: 420rpx;
  border: 0;
  background: transparent;
  padding: 28rpx 28rpx 92rpx;
  color: #1A1A1A;
  font-size: 27rpx;
  line-height: 1.5;
}

.voice-pill {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: auto;
  min-width: 150rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #ECFDF9;
  color: #0F766E;
  gap: 10rpx;
  padding: 0 20rpx;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.voice-pill.recording {
  background: #0F766E;
  color: #FFFFFF;
}

.voice-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  flex: 0 0 30rpx;
}

.voice-icon.mic::before {
  position: absolute;
  left: 8rpx;
  top: 0;
  width: 14rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 14rpx;
  content: "";
}

.voice-icon.mic::after {
  position: absolute;
  left: 3rpx;
  top: 18rpx;
  width: 24rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 10rpx 17rpx 0 -8rpx currentColor;
  content: "";
}

.voice-icon.stop::before {
  position: absolute;
  left: 6rpx;
  top: 6rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 5rpx;
  background: currentColor;
  content: "";
}

.voice-status,
.voice-error {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.45;
}

.voice-status {
  color: #0F766E;
}

.voice-error {
  color: #EE3B2B;
}

.chat-actions {
  margin-top: 20rpx;
}

.send-ai-button {
  background: #0B57D0;
  color: #FFFFFF;
}

.send-ai-button[disabled] {
  background: #F6F6F6;
  color: #A3A3A3;
  opacity: 1;
}

.draft-disclosure {
  margin-top: 18rpx;
}

.draft-item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.draft-item {
  border: 1rpx solid #E6E6E6;
  border-radius: 24rpx;
  background: #FFFFFF;
  padding: 22rpx;
}

.draft-item.muted {
  opacity: 0.58;
}

.draft-item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 18rpx;
}

.draft-item-head > view:first-child {
  min-width: 0;
  flex: 1 1 320rpx;
}

.draft-item-title {
  color: #1A1A1A;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.draft-item-meta {
  margin-top: 6rpx;
  color: #737373;
  font-size: 22rpx;
  line-height: 1.45;
}

.draft-select-control {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  gap: 10rpx;
  flex: 0 0 auto;
  color: #0B57D0;
  font-size: 23rpx;
  font-weight: 800;
}

.editor-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.editor-stack.compact {
  gap: 16rpx;
  margin-top: 18rpx;
}

.editor-stack .field {
  margin-top: 0;
}

.picker-value {
  display: flex;
  height: 88rpx;
  align-items: center;
  max-width: 100%;
  overflow: hidden;
  border-radius: 16rpx;
  background: #F6F6F6;
  padding: 0 24rpx;
  color: #1A1A1A;
  font-size: 28rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.textarea {
  min-height: 264rpx;
}

.report-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.secondary-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.danger-soft-button {
  height: 80rpx;
  border-radius: 24rpx;
  background: #FEF2F2;
  color: #EE3B2B;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 80rpx;
}
