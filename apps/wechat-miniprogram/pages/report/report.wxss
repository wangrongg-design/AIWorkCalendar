.logout {
  flex-shrink: 0;
  width: 112rpx;
}

.ai-status-panel {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 28rpx;
  background: #ECFDF9;
  padding: 24rpx;
}

.ai-status-icon {
  display: flex;
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #CCFBF1;
  color: #0F766E;
  font-size: 24rpx;
  font-weight: 900;
}

.ai-status-copy {
  min-width: 0;
  flex: 1 1 0;
}

.ai-status-kicker {
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 800;
}

.ai-status-title {
  margin-top: 7rpx;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.ai-status-desc {
  margin-top: 6rpx;
  color: #424242;
  font-size: 24rpx;
  line-height: 1.5;
}

.ai-card,
.draft-card {
  padding: 28rpx;
}

.ai-card {
  border-color: #CCFBF1;
  margin-top: 22rpx;
  background: #FFFFFF;
}

.draft-card {
  margin-top: 22rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-top > view:first-child {
  min-width: 0;
}

.chat-list {
  display: flex;
  max-height: 360rpx;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
  overflow: auto;
}

.chat-message {
  max-width: 88%;
  border-radius: 20rpx;
  padding: 18rpx 22rpx;
  font-size: 25rpx;
  line-height: 1.55;
  overflow-wrap: break-word;
  word-break: break-all;
}

.chat-message.assistant {
  align-self: flex-start;
  background: #F6F6F6;
  color: #424242;
}

.chat-message.user {
  align-self: flex-end;
  background: #0B57D0;
  color: #FFFFFF;
}

.chat-input {
  width: 100%;
  min-height: 148rpx;
  margin-top: 20rpx;
  border-radius: 22rpx;
  background: #F6F6F6;
  padding: 22rpx;
  color: #1A1A1A;
  font-size: 26rpx;
  line-height: 1.5;
}

.chat-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.send-ai-button {
  flex: 1 1 0;
  height: 82rpx;
  background: #ECFDF9;
  color: #0F766E;
  line-height: 82rpx;
}

.voice-button {
  flex: 0 0 196rpx;
  max-width: 42%;
  min-width: 0;
  height: 82rpx;
  border-radius: 41rpx;
  background: #F0FDF4;
  color: #16A34A;
  font-size: 27rpx;
  line-height: 82rpx;
  overflow: hidden;
  padding: 0 18rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.voice-button.recording {
  background: #FEF2F2;
  color: #EE3B2B;
}

.voice-error {
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #FEF2F2;
  padding: 16rpx 18rpx;
  color: #EE3B2B;
  font-size: 24rpx;
  line-height: 1.5;
}

.quick-grid,
.title-project-row {
  display: flex;
  gap: 18rpx;
}

.quick-grid .field,
.title-project-row .field {
  min-width: 0;
}

.quick-grid .field:first-child {
  flex: 1 1 0;
}

.quick-grid .field:last-child {
  flex: 0 0 190rpx;
}

.compact-four {
  display: grid;
  grid-template-columns: 1.25fr 0.82fr 0.96fr 0.96fr;
  gap: 12rpx;
}

.compact-four .field,
.compact-four .field:first-child,
.compact-four .field:last-child {
  min-width: 0;
  flex: none;
}

.compact-four .input,
.compact-four .picker-value {
  padding: 0 12rpx;
  font-size: 24rpx;
  text-align: center;
}

.time-value {
  justify-content: center;
}

.title-project-row {
  margin-top: 18rpx;
}

.title-field {
  flex: 0 0 60%;
}

.project-field {
  flex: 1 1 0;
}

.picker-value {
  display: flex;
  height: 88rpx;
  align-items: center;
  max-width: 100%;
  overflow: hidden;
  border-radius: 20rpx;
  background: #F6F6F6;
  padding: 0 24rpx;
  color: #1A1A1A;
  font-size: 28rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-field {
  margin-top: 20rpx;
}

.attachment-actions {
  display: flex;
  gap: 16rpx;
}

.attachment-button {
  flex: 1 1 0;
  min-width: 0;
  height: 78rpx;
  border-radius: 39rpx;
  background: #EEF5FF;
  color: #0B57D0;
  font-size: 26rpx;
  line-height: 78rpx;
}

.attachment-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-radius: 18rpx;
  background: #F6F6F6;
  padding: 16rpx 18rpx;
}

.attachment-info {
  min-width: 0;
}

.attachment-name {
  overflow: hidden;
  color: #1A1A1A;
  font-size: 25rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-meta {
  margin-top: 4rpx;
  color: #737373;
  font-size: 22rpx;
}

.attachment-remove {
  flex: 0 0 112rpx;
  height: 58rpx;
  border-radius: 29rpx;
  background: #FEF2F2;
  color: #EE3B2B;
  font-size: 24rpx;
  line-height: 58rpx;
}

.bottom-actions {
  position: sticky;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  padding: 10rpx;
  box-shadow: 0 12rpx 34rpx rgba(60, 64, 67, 0.14);
}

.bottom-actions button {
  flex: 1 1 0;
  min-width: 0;
}

.submit-button {
  flex: 1.45 1 0;
  box-shadow: 0 8rpx 20rpx rgba(11, 87, 208, 0.18);
}
