<view class="page report-page bottom-safe">
  <view class="report-brief-header">
    <view class="report-title-row">
      <view class="report-title-copy">
        <view class="page-title">今日填报</view>
        <view class="page-subtitle">写一句，AI 整理成可提交日报。</view>
      </view>
      <view class="date-pill">{{datePill}}</view>
    </view>
    <view class="step-row">
      <view class="step-pill {{hasDraftContent ? '' : 'active'}} {{voiceRecognizing ? 'recording' : ''}}">
        <view class="step-icon text-cursor"></view>
        <text>描述</text>
      </view>
      <view class="step-pill {{hasDraftContent ? 'active success' : ''}}">
        <view class="step-icon check-seal"></view>
        <text>确认</text>
      </view>
    </view>
  </view>

  <view class="ios-card composer-card">
    <view class="composer-head">
      <view class="composer-icon"></view>
      <view class="composer-copy">
        <view class="section-title">今天做了什么？</view>
        <view class="section-desc">任务、工时、风险，讲清楚即可。</view>
      </view>
    </view>

    <view class="hint-chip-row">
      <view class="hint-chip">任务</view>
      <view class="hint-chip">工时</view>
      <view class="hint-chip">风险</view>
    </view>

    <view class="ai-generated-note">日报草稿由人工智能生成，请核验后提交。</view>

    <view wx:if="{{chatMessages.length > 1}}" class="chat-list">
      <view wx:for="{{chatMessages}}" wx:key="id" class="chat-message {{item.role}}">
        {{item.content}}
      </view>
    </view>

    <view class="voice-input-box {{voiceRecognizing ? 'recording' : ''}}">
      <textarea
        class="chat-input"
        value="{{chatInput}}"
        maxlength="2000"
        auto-height
        placeholder="例如：完成登录页优化，修复构建问题，耗时 4 小时"
        bindinput="onChatInput"
      />
      <button class="voice-pill {{voiceRecognizing ? 'recording' : ''}}" bindtap="toggleVoiceInput">
        <view class="voice-icon {{voiceRecognizing ? 'stop' : 'mic'}}"></view>
        <text wx:if="{{voiceRecognizing}}">停止</text>
        <text wx:else>语音</text>
      </button>
    </view>

    <view wx:if="{{voiceRecognizing}}" class="voice-status">正在听你说... 最长 60 秒</view>
    <view wx:if="{{voiceError}}" class="voice-error">{{voiceError}}</view>

    <view class="chat-actions">
      <button class="primary-button send-ai-button" loading="{{drafting}}" disabled="{{!chatInput || drafting || voiceRecognizing}}" bindtap="sendChatMessage">生成草稿</button>
    </view>
  </view>

  <view wx:if="{{hasDraftContent}}" class="ios-card draft-card">
    <view class="draft-head">
      <view class="draft-icon"></view>
      <view>
        <view class="section-title">确认草稿</view>
        <view class="section-desc">不会自动提交，改完再确认。</view>
      </view>
    </view>
    <view class="ai-generated-disclosure draft-disclosure">人工智能生成内容</view>

    <view wx:if="{{draftItems.length}}" class="draft-item-list">
      <view wx:for="{{draftItems}}" wx:key="id" class="draft-item {{item.selected ? '' : 'muted'}}">
        <view class="draft-item-head">
          <view>
            <view class="draft-item-title">第 {{index + 1}} 条 · {{item.kind === 'PLAN' ? '计划' : '日报'}}</view>
            <view class="draft-item-meta">置信度 {{item.confidenceText}}<text wx:if="{{item.missingFields}}"> · 需确认：{{item.missingFields}}</text></view>
          </view>
          <view class="draft-select-control">
            <text>{{item.selected ? '确认' : '跳过'}}</text>
            <switch checked="{{item.selected}}" color="#0B57D0" data-index="{{index}}" bindchange="onDraftSelectedChange" />
          </view>
        </view>

        <view class="editor-stack compact">
          <view class="field">
            <text class="field-label">日期</text>
            <picker mode="date" value="{{item.date}}" data-index="{{index}}" bindchange="onDraftDateChange">
              <view class="picker-value">{{item.date}}</view>
            </picker>
          </view>

          <view class="field">
            <text class="field-label">项目</text>
            <picker value="{{item.projectIndex}}" range="{{projectOptions}}" range-key="displayName" data-index="{{index}}" bindchange="onDraftProjectChange">
              <view class="picker-value">{{item.projectName}}</view>
            </picker>
          </view>

          <view class="field">
            <text class="field-label">标题</text>
            <input class="input" value="{{item.title}}" placeholder="例如：完成日报月历联调" data-index="{{index}}" bindinput="onDraftTitleInput" />
          </view>

          <view class="field">
            <text class="field-label">工时</text>
            <input class="input" type="digit" value="{{item.hours}}" data-index="{{index}}" bindinput="onDraftHoursInput" />
          </view>

          <view class="field">
            <text class="field-label">日报内容</text>
            <textarea class="textarea" value="{{item.content}}" maxlength="3000" placeholder="生成后可继续手动补充。" data-index="{{index}}" bindinput="onDraftContentInput" />
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="editor-stack">
      <view class="field">
        <text class="field-label">日期</text>
        <picker mode="date" value="{{date}}" bindchange="onDateChange">
          <view class="picker-value">{{date}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="field-label">项目</text>
        <picker value="{{projectIndex}}" range="{{projectOptions}}" range-key="displayName" bindchange="onProjectChange">
          <view class="picker-value">{{projectOptions[projectIndex].displayName}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="field-label">标题</text>
        <input class="input" value="{{title}}" placeholder="例如：完成日报月历联调" bindinput="onTitleInput" />
      </view>

      <view class="field">
        <text class="field-label">工时</text>
        <input class="input" type="digit" value="{{hours}}" bindinput="onHoursInput" />
      </view>

      <view class="field">
        <text class="field-label">日报内容</text>
        <textarea class="textarea" value="{{content}}" maxlength="3000" placeholder="人工智能生成后可继续手动补充。" bindinput="onContentInput" />
      </view>
    </view>
  </view>

  <view wx:if="{{hasDraftContent}}" class="report-actions">
    <button class="primary-button" loading="{{submitting}}" bindtap="submit">提交</button>
    <view class="secondary-action-row">
      <button class="secondary-button" loading="{{savingDraft}}" bindtap="saveDraft">保存</button>
      <button class="danger-soft-button" bindtap="clearForm">清空</button>
    </view>
  </view>
</view>
