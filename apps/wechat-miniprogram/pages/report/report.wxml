<view class="page report-page bottom-safe">
  <view class="report-header">
    <view>
      <view class="report-greeting">你好，{{user.name || "同事"}}</view>
      <view class="page-subtitle">{{user.tenantName || ""}}</view>
    </view>
  </view>

  <view class="ai-action-card today-status-panel">
    <view class="ai-action-icon">{{todayStatusIcon}}</view>
    <view class="ai-action-copy">
      <view class="ai-action-kicker">AI 洞察</view>
      <view class="ai-action-title">{{todayConclusion}}</view>
      <view class="ai-action-desc">{{todayRiskText}}</view>
    </view>
  </view>

  <view class="ios-card ai-card">
    <view class="section-title">今天你完成了什么？</view>
    <view class="section-desc">一句话即可，AI 会整理成日报。</view>

    <view wx:if="{{chatMessages.length > 1}}" class="chat-list">
      <view wx:for="{{chatMessages}}" wx:key="id" class="chat-message {{item.role}}">
        {{item.content}}
      </view>
    </view>

    <textarea class="chat-input" value="{{chatInput}}" maxlength="2000" placeholder="例如：完成登录页重构，修复构建问题，推进项目日历风险提示，耗时 4 小时" bindinput="onChatInput" />

    <view class="chat-actions">
      <button class="primary-button send-ai-button" loading="{{drafting}}" bindtap="sendChatMessage">AI 帮我整理日报</button>
    </view>
  </view>

  <view wx:if="{{hasDraftContent}}" class="ios-card draft-card">
    <view class="section-title">日报草稿</view>
    <view class="section-desc">AI 生成后仍可手动校正，提交前请确认工时和项目。</view>

    <view class="editor-stack">
      <view class="field">
        <text class="field-label">日期</text>
        <picker mode="date" value="{{date}}" bindchange="onDateChange">
          <view class="picker-value">{{date}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="field-label">项目</text>
        <picker value="{{projectIndex}}" range="{{projectOptions}}" range-key="displayName" bindchange="onProjectChange">
          <view class="picker-value">{{projectOptions[projectIndex].displayName}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="field-label">标题</text>
        <input class="input" value="{{title}}" placeholder="例如：完成日报月历联调" bindinput="onTitleInput" />
      </view>

      <view class="field">
        <text class="field-label">工时</text>
        <input class="input" type="digit" value="{{hours}}" bindinput="onHoursInput" />
      </view>

      <view class="field">
        <text class="field-label">日报内容</text>
        <textarea class="textarea" value="{{content}}" maxlength="3000" placeholder="AI 生成后可继续手动补充。" bindinput="onContentInput" />
      </view>
    </view>
  </view>

  <view class="report-actions">
    <button class="primary-button" loading="{{submitting}}" bindtap="submit">提交今日工作</button>
    <button class="secondary-button" loading="{{savingDraft}}" bindtap="saveDraft">保存为草稿</button>
    <button class="tertiary-button" bindtap="clearForm">清空</button>
  </view>
</view>
