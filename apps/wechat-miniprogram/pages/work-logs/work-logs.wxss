.list-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.log-filter-tabs {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.search-shell {
  display: flex;
  align-items: center;
  height: 88rpx;
  gap: 20rpx;
  width: 100%;
  border: 1rpx solid #E6E6E6;
  border-radius: 44rpx;
  background: #FFFFFF;
  padding: 0 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.05);
}

.search-leading {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 34rpx;
  border: 6rpx solid #1A1A1A;
  border-radius: 50%;
}

.search-leading::after {
  position: absolute;
  right: -9rpx;
  bottom: -6rpx;
  width: 17rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #1A1A1A;
  content: "";
  transform: rotate(45deg);
}

.search-input {
  flex: 1 1 0;
  height: 86rpx;
  min-width: 0;
  background: transparent;
  color: #1A1A1A;
  font-size: 28rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  overflow: hidden;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
}

.log-row {
  background: #FFFFFF;
  padding: 24rpx;
}

.log-row + .log-row {
  border-top: 1rpx solid #E6E6E6;
}

.log-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.log-title {
  min-width: 0;
  flex: 1 1 0;
  overflow: hidden;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.32;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #F6F6F6;
  padding: 7rpx 14rpx;
  color: #737373;
  font-size: 21rpx;
  font-weight: 800;
}

.status-badge.success {
  background: #F0FDF4;
  color: #16A34A;
}

.log-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #737373;
  font-size: 23rpx;
}

.log-meta text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-preview {
  margin-top: 12rpx;
  overflow: hidden;
  color: #424242;
  font-size: 25rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.risk-line {
  margin-top: 12rpx;
  color: #EE3B2B;
  font-size: 23rpx;
  font-weight: 700;
}

.log-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.log-action {
  width: auto;
  min-width: 104rpx;
  height: 60rpx;
  border-radius: 18rpx;
  padding: 0 20rpx;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.log-action.submit {
  background: #EEF5FF;
  color: #0B57D0;
}

.log-action.delete {
  background: #FEF2F2;
  color: #EE3B2B;
}

.loading {
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}
