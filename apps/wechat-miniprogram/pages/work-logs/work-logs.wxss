.list-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.log-filter-tabs {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.search-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 24rpx;
  background: #FFFFFF;
  padding: 0 26rpx;
  color: #1A1A1A;
  font-size: 27rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  overflow: hidden;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
}

.log-row {
  background: #FFFFFF;
  padding: 24rpx;
}

.log-row + .log-row {
  border-top: 1rpx solid #E6E6E6;
}

.log-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.log-title {
  min-width: 0;
  flex: 1 1 0;
  overflow: hidden;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.32;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #F6F6F6;
  padding: 7rpx 14rpx;
  color: #737373;
  font-size: 21rpx;
  font-weight: 800;
}

.status-badge.success {
  background: #F0FDF4;
  color: #16A34A;
}

.log-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #737373;
  font-size: 23rpx;
}

.log-meta text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-preview {
  margin-top: 12rpx;
  overflow: hidden;
  color: #424242;
  font-size: 25rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.risk-line {
  margin-top: 12rpx;
  color: #EE3B2B;
  font-size: 23rpx;
  font-weight: 700;
}

.loading {
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}
