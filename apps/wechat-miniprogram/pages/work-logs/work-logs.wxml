<view class="page list-page bottom-safe">
  <view class="search-shell">
    <view class="search-leading"></view>
    <input class="search-input" value="{{searchText}}" placeholder="搜索标题、内容或项目" bindinput="onSearchInput" />
  </view>

  <view class="segmented-control log-filter-tabs">
    <view
      wx:for="{{filters}}"
      wx:key="value"
      class="segmented-item {{filterIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onFilterTap"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{!filteredLogs.length && !loading}}" class="empty-state">
    <view class="empty-title">{{emptyTitle}}</view>
    <view class="empty-desc">{{emptyDesc}}</view>
  </view>

  <view wx:if="{{filteredLogs.length}}" class="list-stack">
    <view wx:for="{{filteredLogs}}" wx:key="id" class="log-row" data-id="{{item.id}}" bindtap="openLog">
      <view class="log-head">
        <view class="log-title">{{item.title}}</view>
        <view class="status-badge {{item.statusTone}}">{{item.statusTitle}}</view>
      </view>
      <view class="log-meta">
        <text>{{item.dateText}}</text>
        <text>{{item.hoursText}}h</text>
        <text wx:if="{{item.projectName}}">{{item.projectName}}</text>
      </view>
      <view class="log-preview">{{item.contentPreview}}</view>
      <view wx:if="{{item.hasRisk}}" class="risk-line">AI 发现风险或阻塞</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
