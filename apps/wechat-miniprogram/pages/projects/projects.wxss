.projects-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.project-ai-panel {
  margin-top: 0;
}

.project-ai-action {
  width: 196rpx;
  height: 64rpx;
  margin-top: 18rpx;
  border-radius: 20rpx;
  background: #0F766E;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
}

.project-ai-action.active {
  background: #FEF2F2;
  color: #EE3B2B;
}

.search-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 24rpx;
  background: #FFFFFF;
  padding: 0 26rpx;
  color: #1A1A1A;
  font-size: 27rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  overflow: hidden;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
}

.project-row {
  background: #FFFFFF;
  padding: 24rpx;
}

.project-row + .project-row {
  border-top: 1rpx solid #E6E6E6;
}

.project-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.project-name {
  min-width: 0;
  flex: 1 1 0;
  overflow: hidden;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #F6F6F6;
  padding: 7rpx 14rpx;
  color: #737373;
  font-size: 21rpx;
  font-weight: 800;
}

.status-badge.success {
  background: #F0FDF4;
  color: #16A34A;
}

.status-badge.warning {
  background: #FFFBEB;
  color: #D97706;
}

.project-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #737373;
  font-size: 23rpx;
}

.project-meta text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-risk {
  margin-top: 12rpx;
  color: #0F766E;
  font-size: 23rpx;
  line-height: 1.45;
}

.project-risk.risk {
  color: #EE3B2B;
}

.loading {
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}
