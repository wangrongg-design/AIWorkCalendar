.projects-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.list-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 4rpx;
}

.list-header > view:first-child {
  min-width: 0;
  flex: 1 1 0;
}

.risk-filter-button {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  flex: 0 0 80rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #424242;
  border: 1rpx solid #E6E6E6;
}

.risk-filter-button.active {
  background: #FFFBEB;
  color: #D97706;
  border-color: #FEF3C7;
}

.risk-filter-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
}

.risk-filter-icon::before {
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  content: "";
  transform: rotate(135deg) skew(10deg, 10deg);
}

.risk-filter-icon::after {
  position: absolute;
  left: 16rpx;
  bottom: 3rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: currentColor;
  content: "";
}

.search-shell {
  display: flex;
  align-items: center;
  height: 88rpx;
  gap: 20rpx;
  width: 100%;
  border: 1rpx solid #E6E6E6;
  border-radius: 44rpx;
  background: #FFFFFF;
  padding: 0 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(60, 64, 67, 0.08);
}

.search-leading {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 34rpx;
  border: 6rpx solid #1A1A1A;
  border-radius: 50%;
}

.search-leading::after {
  position: absolute;
  right: -9rpx;
  bottom: -6rpx;
  width: 17rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #1A1A1A;
  content: "";
  transform: rotate(45deg);
}

.search-input {
  flex: 1 1 0;
  height: 86rpx;
  min-width: 0;
  background: transparent;
  color: #1A1A1A;
  font-size: 32rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  overflow: hidden;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
}

.project-row {
  background: #FFFFFF;
  padding: 24rpx;
}

.project-row + .project-row {
  border-top: 1rpx solid #E6E6E6;
}

.project-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.project-name {
  min-width: 0;
  flex: 1 1 0;
  overflow: hidden;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #F6F6F6;
  padding: 7rpx 14rpx;
  color: #737373;
  font-size: 21rpx;
  font-weight: 800;
}

.status-badge.success {
  background: #F0FDF4;
  color: #16A34A;
}

.status-badge.warning {
  background: #FFFBEB;
  color: #D97706;
}

.project-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #737373;
  font-size: 23rpx;
}

.project-meta text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-risk {
  margin-top: 12rpx;
  color: #0F766E;
  font-size: 23rpx;
  line-height: 1.45;
}

.project-risk.risk {
  color: #EE3B2B;
}

.loading {
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}
