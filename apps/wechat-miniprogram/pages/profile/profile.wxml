<view class="page profile-page bottom-safe">
  <view class="profile-header">
    <view class="profile-name">{{user.name}}</view>
    <view class="profile-subtitle">{{user.tenantName}} · {{departmentText}}</view>
  </view>

  <view class="metric-grid">
    <view class="metric-card">
      <view class="metric-value">{{todayCount}}</view>
      <view class="metric-label">今日填报</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">{{todayHours}}h</view>
      <view class="metric-label">今日工时</view>
    </view>
    <view class="metric-card">
      <view class="metric-value risk">{{todayRiskCount}}</view>
      <view class="metric-label">风险信号</view>
    </view>
    <view class="metric-card">
      <view class="metric-value ai">{{weeklyHours}}h</view>
      <view class="metric-label">近 7 日</view>
    </view>
  </view>

  <view class="ai-profile-panel">
    <view class="ai-kicker">AI 工作画像</view>
    <view class="ai-title">{{profileConclusion}}</view>
    <view class="ai-desc">{{profileRiskText}}</view>
  </view>

  <view class="surface profile-section">
    <view class="section-title">企业与权限</view>
    <view class="info-row">
      <text>企业</text>
      <text>{{user.tenantName}}</text>
    </view>
    <view class="info-row">
      <text>企业代码</text>
      <text>{{user.tenantCode}}</text>
    </view>
    <view class="info-row">
      <text>部门</text>
      <text>{{departmentText}}</text>
    </view>
    <view class="info-row">
      <text>邮箱</text>
      <text>{{emailText}}</text>
    </view>
    <view class="info-row">
      <text>角色</text>
      <text>{{rolesText}}</text>
    </view>
  </view>

  <button class="danger-button logout-button" bindtap="logout">退出登录</button>
</view>
