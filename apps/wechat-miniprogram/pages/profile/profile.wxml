<view class="page profile-page bottom-safe">
  <view class="profile-header">
    <view class="profile-name">{{user.name}}</view>
    <view class="profile-subtitle">{{user.tenantName}} · {{departmentText}}</view>
  </view>

  <view class="surface profile-section">
    <view class="section-title">账号</view>
    <view class="info-row">
      <text>姓名</text>
      <text>{{user.name}}</text>
    </view>
    <view class="info-row">
      <text>邮箱</text>
      <text>{{emailText}}</text>
    </view>
    <view wx:if="{{user.phone}}" class="info-row">
      <text>手机</text>
      <text>{{user.phone}}</text>
    </view>
    <view class="info-row">
      <text>角色</text>
      <text>{{rolesText}}</text>
    </view>
  </view>

  <view class="surface profile-section">
    <view class="section-title">组织</view>
    <view class="info-row">
      <text>企业</text>
      <text>{{user.tenantName}}</text>
    </view>
    <view class="info-row">
      <text>企业代码</text>
      <text>{{user.tenantCode}}</text>
    </view>
    <view class="info-row">
      <text>部门</text>
      <text>{{departmentText}}</text>
    </view>
  </view>

  <button class="danger-button logout-button" bindtap="logout">退出登录</button>
</view>
