.profile-header {
  padding: 4rpx 0 8rpx;
}

.profile-page {
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.profile-name {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.16;
  word-break: break-all;
}

.profile-subtitle {
  max-width: 100%;
  margin-top: 10rpx;
  color: #737373;
  font-size: 25rpx;
  line-height: 1.45;
  word-break: break-all;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.metric-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 118rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(60, 64, 67, 0.035);
}

.metric-icon {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 58rpx;
  border-radius: 18rpx;
  background: #EEF5FF;
  color: #0B57D0;
}

.document-icon::before {
  position: absolute;
  left: 17rpx;
  top: 11rpx;
  width: 24rpx;
  height: 34rpx;
  border: 5rpx solid currentColor;
  border-radius: 4rpx;
  content: "";
}

.clock-icon {
  background: #ECFDF9;
  color: #0B57D0;
}

.clock-icon::before {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  width: 30rpx;
  height: 30rpx;
  border: 5rpx solid currentColor;
  border-radius: 50%;
  content: "";
}

.clock-icon::after {
  position: absolute;
  left: 28rpx;
  top: 20rpx;
  width: 5rpx;
  height: 17rpx;
  border-radius: 5rpx;
  background: currentColor;
  box-shadow: 8rpx 12rpx 0 -1rpx currentColor;
  content: "";
}

.warning-icon {
  background: #FEF2F2;
  color: #D97706;
}

.warning-icon::before {
  position: absolute;
  left: 14rpx;
  top: 12rpx;
  width: 28rpx;
  height: 28rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  content: "";
  transform: rotate(135deg) skew(10deg, 10deg);
}

.trend-icon {
  background: #ECFDF9;
  color: #0F766E;
}

.trend-icon::before {
  position: absolute;
  left: 14rpx;
  bottom: 15rpx;
  width: 31rpx;
  height: 24rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  content: "";
}

.trend-icon::after {
  position: absolute;
  right: 12rpx;
  top: 15rpx;
  width: 22rpx;
  height: 5rpx;
  border-radius: 5rpx;
  background: currentColor;
  content: "";
  transform: rotate(-38deg);
}

.metric-value {
  margin-top: 4rpx;
  overflow: hidden;
  color: #0B57D0;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.18;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-value.risk {
  color: #EE3B2B;
}

.metric-value.ai {
  color: #0F766E;
}

.metric-label {
  margin-top: 0;
  color: #737373;
  font-size: 23rpx;
}

.ai-profile-panel {
  margin-top: 20rpx;
}

.profile-section {
  margin-top: 20rpx;
  padding: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid #E6E6E6;
  padding-top: 20rpx;
  margin-top: 20rpx;
  color: #424242;
  font-size: 26rpx;
}

.info-row text:first-child {
  flex-shrink: 0;
  color: #737373;
}

.info-row text:last-child {
  min-width: 0;
  text-align: right;
  word-break: break-all;
}

.logout-button {
  margin-top: 24rpx;
}
