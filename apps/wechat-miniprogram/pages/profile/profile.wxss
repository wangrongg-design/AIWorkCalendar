.profile-header {
  padding: 4rpx 0 8rpx;
}

.profile-page {
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.profile-name {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.16;
  word-break: break-all;
}

.profile-subtitle {
  max-width: 100%;
  margin-top: 10rpx;
  color: #737373;
  font-size: 25rpx;
  line-height: 1.45;
  word-break: break-all;
}

.profile-section {
  margin-top: 20rpx;
  padding: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid #E6E6E6;
  padding-top: 20rpx;
  margin-top: 20rpx;
  color: #424242;
  font-size: 26rpx;
}

.info-row text:first-child {
  flex-shrink: 0;
  color: #737373;
}

.info-row text:last-child {
  min-width: 0;
  text-align: right;
  word-break: break-all;
}

.logout-button {
  margin-top: 24rpx;
}
