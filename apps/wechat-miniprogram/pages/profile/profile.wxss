.profile-header {
  padding: 4rpx 0 8rpx;
}

.profile-name {
  max-width: 100%;
  color: #1A1A1A;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.16;
  word-break: break-all;
}

.profile-subtitle {
  max-width: 100%;
  margin-top: 10rpx;
  color: #737373;
  font-size: 25rpx;
  line-height: 1.45;
  word-break: break-all;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.metric-card {
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(60, 64, 67, 0.035);
}

.metric-value {
  overflow: hidden;
  color: #0B57D0;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.18;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-value.risk {
  color: #EE3B2B;
}

.metric-value.ai {
  color: #0F766E;
}

.metric-label {
  margin-top: 8rpx;
  color: #737373;
  font-size: 23rpx;
}

.ai-profile-panel {
  margin-top: 20rpx;
}

.profile-section {
  margin-top: 20rpx;
  padding: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid #E6E6E6;
  padding-top: 20rpx;
  margin-top: 20rpx;
  color: #424242;
  font-size: 26rpx;
}

.info-row text:first-child {
  flex-shrink: 0;
  color: #737373;
}

.info-row text:last-child {
  min-width: 0;
  text-align: right;
  word-break: break-all;
}

.logout-button {
  margin-top: 24rpx;
}
