<view class="page calendar-page bottom-safe">
  <view class="calendar-topbar">
    <picker mode="date" fields="month" value="{{month}}" bindchange="onMonthChange">
      <view class="month-trigger">
        <view class="month-title">{{monthTitle}}</view>
        <view class="month-chevron"></view>
      </view>
    </picker>
    <view class="toolbar-actions">
      <button class="toolbar-button search-button" bindtap="openSearch">
        <view class="top-icon search-icon"></view>
      </button>
      <button class="toolbar-button today-button" bindtap="goToday">
        <view class="top-icon today-icon">
          <view></view>
        </view>
      </button>
      <picker range="{{scopeOptions}}" range-key="label" value="{{scopeIndex}}" bindchange="onScopeChange">
        <view class="toolbar-button">
          <view class="top-icon scope-person">
            <view></view>
          </view>
        </view>
      </picker>
    </view>
  </view>

  <view class="ai-summary-card" bindtap="openFirstRiskDay">
    <view class="ai-icon">{{aiIconText}}</view>
    <view class="ai-copy">
      <view class="ai-kicker">AI 今日摘要</view>
      <view class="ai-title">{{aiConclusion}}</view>
      <view class="ai-desc">{{aiRiskText}}</view>
    </view>
    <view wx:if="{{firstRiskDate}}" class="ai-chevron">›</view>
  </view>

  <view class="status-summary">
    <view class="metric">
      <view class="metric-value {{monthFillRateTone}}">{{monthFillRate}}%</view>
      <view class="metric-label">填报率</view>
    </view>
    <view class="metric">
      <view class="metric-value warning">{{missingCount}}</view>
      <view class="metric-label">未填</view>
    </view>
    <view class="metric">
      <view class="metric-value risk">{{riskDayCount}}</view>
      <view class="metric-label">风险</view>
    </view>
  </view>

  <view class="calendar-card">
    <view class="week-row">
      <text wx:for="{{weekdays}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="grid">
      <view
        wx:for="{{grid}}"
        wx:key="id"
        class="calendar-cell {{item.blank ? 'blank' : item.tone}} {{item.isToday ? 'today' : ''}}"
        data-date="{{item.date}}"
        bindtap="openDay"
      >
        <block wx:if="{{!item.blank}}">
          <view class="day-line">
            <text class="day">{{item.day}}</text>
          </view>
          <view class="cell-spacer"></view>
          <view class="cell-foot">
            <view class="status-bar {{item.tone}}"></view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="analysis-entry" bindtap="openAnalysis">
    <view class="analysis-entry-copy">
      <view class="analysis-kicker">AI 整体分析</view>
      <view class="analysis-title">{{analysisTitle}}</view>
      <view class="analysis-desc">{{analysisDesc}}</view>
      <view class="analysis-periods">本周 / 本月 / 季度 / 年度</view>
    </view>
    <view class="analysis-action">查看分析</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <button class="calendar-fab" bindtap="createReport">+</button>
</view>
