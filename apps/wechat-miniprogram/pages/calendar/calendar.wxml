<view class="page calendar-page bottom-safe">
  <view class="calendar-home-header">
    <view class="header-main">
      <view>
        <view class="page-title">AI日历</view>
        <view class="page-subtitle">{{homeSubtitle}}</view>
        <view class="ai-generated-disclosure calendar-disclosure">人工智能生成提示</view>
      </view>
      <button class="refresh-button" bindtap="loadHome">
        <view class="refresh-icon"></view>
      </button>
    </view>
  </view>

  <view class="daily-status-card">
    <view class="ai-generated-disclosure">人工智能生成</view>
    <view class="status-main">
      <view class="status-icon {{todayBrief.tone}}"></view>
      <view class="status-copy">
        <view class="status-title">{{todayBrief.title}}</view>
        <view class="status-summary">{{todayBrief.summary}}</view>
      </view>
    </view>
    <view class="status-message {{todayBrief.tone}}">{{todayBrief.message}}</view>
  </view>

  <view class="weekly-digest-card">
    <view class="digest-head">
      <view class="section-title">本周简报</view>
      <view class="digest-range">{{weekRange}}</view>
    </view>
    <view class="brief-metrics">
      <view wx:for="{{weekMetrics}}" wx:key="label" class="brief-metric {{item.tone}}">
        <view class="brief-value">{{item.value}}</view>
        <view class="brief-label">{{item.label}}</view>
      </view>
    </view>
    <view class="digest-divider"></view>
    <view class="digest-attention">
      <view wx:if="{{!hasAttention}}" class="empty-row">
        <view class="empty-icon success"></view>
        <view class="empty-copy">
          <view class="empty-title">暂无需要关注的问题</view>
          <view class="empty-text">有异常时会优先显示在这里。</view>
        </view>
      </view>
      <view
        wx:for="{{attentionItems}}"
        wx:key="id"
        class="attention-row"
        data-date="{{item.dateKey}}"
        bindtap="openAttention"
      >
        <view class="row-icon {{item.tone}}"></view>
        <view class="row-copy">
          <view class="row-title">{{item.title}}</view>
          <view class="row-subtitle">{{item.subtitle}}</view>
        </view>
        <view class="chevron">›</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>
