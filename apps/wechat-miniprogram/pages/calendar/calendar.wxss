.calendar-page {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding-top: 28rpx;
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.calendar-home-header {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.header-main,
.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.header-main > view:first-child,
.section-head > view:first-child {
  min-width: 0;
}

.calendar-disclosure {
  margin-top: 12rpx;
}

.refresh-button {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  flex: 0 0 80rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 50%;
  background: #FFFFFF;
  color: #2E2E2E;
}

.refresh-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid currentColor;
  border-left-color: transparent;
  border-radius: 50%;
  transform: rotate(-26deg);
}

.refresh-icon::after {
  position: absolute;
  right: -7rpx;
  top: -5rpx;
  width: 0;
  height: 0;
  border-left: 11rpx solid currentColor;
  border-top: 7rpx solid transparent;
  border-bottom: 7rpx solid transparent;
  content: "";
  transform: rotate(30deg);
}

.daily-status-card {
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 32rpx;
}

.daily-status-card .ai-generated-disclosure {
  margin-bottom: 22rpx;
}

.status-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.status-icon,
.row-icon,
.empty-icon {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 76rpx;
  border-radius: 24rpx;
  background: #F0FDF4;
  color: #16A34A;
}

.row-icon,
.empty-icon {
  width: 60rpx;
  height: 60rpx;
  flex-basis: 60rpx;
  border-radius: 18rpx;
}

.status-icon::before,
.empty-icon.success::before {
  position: absolute;
  left: 24rpx;
  top: 19rpx;
  width: 26rpx;
  height: 16rpx;
  border-left: 6rpx solid currentColor;
  border-bottom: 6rpx solid currentColor;
  content: "";
  transform: rotate(-45deg);
}

.status-icon.warning,
.row-icon.warning {
  background: #FFFBEB;
  color: #D97706;
}

.status-icon.warning::before,
.row-icon.warning::before {
  position: absolute;
  left: 23rpx;
  top: 17rpx;
  width: 20rpx;
  height: 22rpx;
  border: 5rpx solid currentColor;
  border-radius: 50%;
  content: "";
}

.status-icon.warning::after,
.row-icon.warning::after {
  position: absolute;
  left: 36rpx;
  top: 42rpx;
  width: 5rpx;
  height: 12rpx;
  border-radius: 5rpx;
  background: currentColor;
  content: "";
}

.status-icon.risk,
.row-icon.risk {
  background: #FEF2F2;
  color: #EE3B2B;
}

.status-icon.risk::before,
.row-icon.risk::before {
  position: absolute;
  left: 25rpx;
  top: 15rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 6rpx solid currentColor;
  border-bottom: 6rpx solid currentColor;
  content: "";
  transform: rotate(135deg) skew(10deg, 10deg);
}

.row-icon.warning::before {
  left: 17rpx;
  top: 13rpx;
}

.row-icon.warning::after {
  left: 28rpx;
  top: 34rpx;
}

.row-icon.risk::before {
  left: 18rpx;
  top: 12rpx;
}

.status-copy,
.row-copy {
  min-width: 0;
  flex: 1 1 0;
}

.status-title {
  color: #1A1A1A;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.status-summary {
  margin-top: 8rpx;
  color: #737373;
  font-size: 27rpx;
  line-height: 1.42;
}

.status-message {
  margin-top: 24rpx;
  color: #424242;
  font-size: 28rpx;
  line-height: 1.5;
}

.status-message.risk {
  color: #EE3B2B;
}

.section-title {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.weekly-digest-card {
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 32rpx;
}

.digest-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.digest-range {
  flex-shrink: 0;
  color: #737373;
  font-size: 22rpx;
  line-height: 1.3;
}

.brief-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.brief-metric {
  min-width: 0;
  border: 1rpx solid rgba(230, 230, 230, 0.8);
  border-radius: 24rpx;
  background: #F6F6F6;
  padding: 22rpx;
}

.brief-metric.success {
  background: #F0FDF4;
}

.brief-metric.warning {
  background: #FFFBEB;
}

.brief-metric.risk {
  background: #FEF2F2;
}

.brief-value {
  overflow: hidden;
  color: #737373;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brief-metric.success .brief-value {
  color: #16A34A;
}

.brief-metric.warning .brief-value {
  color: #D97706;
}

.brief-metric.risk .brief-value {
  color: #EE3B2B;
}

.brief-label {
  margin-top: 6rpx;
  color: #737373;
  font-size: 22rpx;
}

.digest-divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: #E6E6E6;
}

.digest-attention {
  overflow: hidden;
}

.attention-row,
.empty-row {
  display: flex;
  min-height: 104rpx;
  align-items: center;
  gap: 20rpx;
  padding: 0;
}

.attention-row + .attention-row {
  border-top: 1rpx solid #E6E6E6;
  margin-top: 22rpx;
  padding-top: 22rpx;
}

.row-title {
  overflow: hidden;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-subtitle,
.empty-text {
  margin-top: 6rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.4;
}

.empty-text {
  margin-top: 4rpx;
}

.empty-copy {
  min-width: 0;
}

.empty-title {
  color: #1A1A1A;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.chevron {
  flex: 0 0 auto;
  color: #A3A3A3;
  font-size: 38rpx;
  line-height: 1;
}

.text-link {
  width: auto;
  min-width: 128rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #0B57D0;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.risk-badge {
  flex: 0 0 auto;
  border-radius: 999rpx;
  background: #FEF2F2;
  padding: 8rpx 16rpx;
  color: #EE3B2B;
  font-size: 22rpx;
  font-weight: 800;
}

.loading {
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}
