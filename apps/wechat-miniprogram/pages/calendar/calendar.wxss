.calendar-page {
  padding-top: 18rpx;
  padding-bottom: calc(206rpx + env(safe-area-inset-bottom));
}

.calendar-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.month-trigger {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 14rpx;
}

.month-title {
  min-width: 0;
  color: #1A1A1A;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.14;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.month-chevron {
  width: 18rpx;
  height: 18rpx;
  border-right: 5rpx solid #737373;
  border-bottom: 5rpx solid #737373;
  transform: rotate(45deg) translateY(-4rpx);
}

.toolbar-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 14rpx;
}

.toolbar-button {
  width: 76rpx;
  min-width: 76rpx;
  height: 76rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #2E2E2E;
  box-shadow: 0 4rpx 14rpx rgba(60, 64, 67, 0.04);
}

.top-icon {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  color: #2E2E2E;
}

.search-icon {
  border: 6rpx solid currentColor;
  border-radius: 50%;
}

.search-icon::after {
  position: absolute;
  right: -8rpx;
  bottom: -5rpx;
  width: 18rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: currentColor;
  content: "";
  transform: rotate(45deg);
}

.today-icon {
  border: 5rpx solid currentColor;
  border-radius: 7rpx;
}

.today-icon::before {
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  top: 12rpx;
  height: 5rpx;
  border-radius: 5rpx;
  background: currentColor;
  content: "";
}

.today-icon view {
  position: absolute;
  right: -6rpx;
  bottom: -6rpx;
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
  background: currentColor;
}

.scope-person::before {
  position: absolute;
  left: 12rpx;
  top: 2rpx;
  width: 15rpx;
  height: 15rpx;
  border: 5rpx solid currentColor;
  border-radius: 50%;
  content: "";
}

.scope-person view {
  position: absolute;
  left: 7rpx;
  bottom: 1rpx;
  width: 24rpx;
  height: 16rpx;
  border: 5rpx solid currentColor;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  border-bottom: 0;
}

.ai-summary-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 24rpx;
}

.ai-icon {
  display: flex;
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #CCFBF1;
  color: #0F766E;
  font-size: 24rpx;
  font-weight: 900;
}

.ai-copy {
  min-width: 0;
  flex: 1 1 0;
}

.ai-kicker {
  color: #0F766E;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.2;
}

.ai-title {
  margin-top: 8rpx;
  color: #1A1A1A;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.42;
}

.ai-desc {
  margin-top: 5rpx;
  color: #737373;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-chevron {
  color: #A3A3A3;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 60rpx;
}

.status-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 20rpx 0;
}

.metric {
  min-width: 0;
  border: 1rpx solid #E6E6E6;
  border-radius: 28rpx;
  background: #FFFFFF;
  padding: 18rpx 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(60, 64, 67, 0.035);
}

.metric-value {
  overflow: hidden;
  color: #0B57D0;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.12;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-value.success {
  color: #16A34A;
}

.metric-value.warning {
  color: #D97706;
}

.metric-value.risk {
  color: #EE3B2B;
}

.metric-value.ai {
  color: #0F766E;
}

.metric-label {
  margin-top: 6rpx;
  color: #737373;
  font-size: 21rpx;
  line-height: 1.2;
}

.calendar-card {
  padding: 0;
}

.week-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  padding: 0 0 10rpx;
  color: #737373;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.week-row text {
  border-radius: 18rpx;
  background: #FFFFFF;
  line-height: 52rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.calendar-cell {
  display: flex;
  min-height: 148rpx;
  flex-direction: column;
  border: 1rpx solid #E6E6E6;
  border-radius: 20rpx;
  background: #FFFFFF;
  padding: 18rpx 14rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(60, 64, 67, 0.035);
}

.calendar-cell.blank {
  border-color: rgba(230, 230, 230, 0.35);
  background: rgba(255, 255, 255, 0.55);
  box-shadow: none;
}

.calendar-cell.empty {
  color: #737373;
}

.calendar-cell.normal {
  color: #0B57D0;
}

.calendar-cell.good {
  color: #16A34A;
}

.calendar-cell.risk {
  border-color: #FEE2E2;
  background: #FEF2F2;
}

.calendar-cell.today {
  border: 2rpx solid #0B57D0;
  background: #EEF5FF;
  color: #1A1A1A;
  box-shadow: 0 10rpx 24rpx rgba(11, 87, 208, 0.18);
}

.day-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-width: 0;
  gap: 4rpx;
}

.day {
  color: #2E2E2E;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.2;
}

.today .day {
  color: #0B57D0;
}

.cell-spacer {
  flex: 1 1 0;
  min-height: 16rpx;
}

.cell-foot {
  display: block;
  margin-top: 7rpx;
}

.status-bar {
  width: 24rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #D97706;
}

.status-bar.normal {
  background: #0B57D0;
}

.status-bar.good {
  background: #16A34A;
}

.status-bar.risk {
  background: #EE3B2B;
}

.analysis-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
  border: 1rpx solid #CCFBF1;
  border-radius: 32rpx;
  background: #ECFDF9;
  padding: 24rpx;
}

.analysis-entry-copy {
  min-width: 0;
  flex: 1 1 0;
}

.analysis-kicker {
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 900;
}

.analysis-title {
  margin-top: 8rpx;
  color: #1A1A1A;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.analysis-desc {
  margin-top: 6rpx;
  color: #424242;
  font-size: 24rpx;
  line-height: 1.5;
}

.analysis-periods {
  margin-top: 12rpx;
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 800;
}

.analysis-action {
  flex: 0 0 132rpx;
  border-radius: 20rpx;
  background: #0F766E;
  padding: 18rpx 10rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.loading {
  margin-top: 20rpx;
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}

.calendar-fab {
  position: fixed;
  right: 58rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  z-index: 3000;
  width: 118rpx;
  height: 118rpx;
  border-radius: 59rpx;
  background: #0B57D0;
  color: #FFFFFF;
  font-size: 64rpx;
  font-weight: 400;
  line-height: 112rpx;
  box-shadow: 0 18rpx 36rpx rgba(11, 87, 208, 0.28);
}
