.ai-detail-card {
  border: 1rpx solid #CCFBF1;
  border-radius: 32rpx;
  background: #ECFDF9;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.ai-detail-card.warning {
  border-color: #FEF3C7;
  background: #FFFBEB;
}

.ai-detail-card.risk {
  border-color: #FEE2E2;
  background: #FEF2F2;
}

.ai-kicker {
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 900;
}

.ai-detail-card.warning .ai-kicker {
  color: #D97706;
}

.ai-detail-card.risk .ai-kicker {
  color: #EE3B2B;
}

.ai-title {
  margin-top: 8rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
}

.ai-desc {
  margin-top: 6rpx;
  color: #424242;
  font-size: 24rpx;
  line-height: 1.5;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  padding: 0;
}

.metric {
  background: #FFFFFF;
  padding: 22rpx 10rpx;
  text-align: center;
}

.metric-value {
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 800;
}

.metric-value.risk {
  color: #EE3B2B;
}

.metric-label {
  margin-top: 8rpx;
  color: #737373;
  font-size: 21rpx;
}

.detail-section {
  margin-top: 20rpx;
  padding: 32rpx;
}

.empty {
  border-radius: 16rpx;
  background: #F6F6F6;
  color: #A3A3A3;
  font-size: 26rpx;
  line-height: 96rpx;
  text-align: center;
}

.employee {
  padding: 22rpx 0;
}

.employee + .employee {
  border-top: 1rpx solid #E6E6E6;
}

.employee-name {
  max-width: 100%;
  font-size: 30rpx;
  font-weight: 800;
  word-break: break-all;
}

.dept {
  margin-top: 6rpx;
  font-size: 22rpx;
}

.log-card {
  margin-top: 16rpx;
  border-radius: 20rpx;
  background: #F6F6F6;
  padding: 22rpx;
}

.log-title {
  max-width: 100%;
  font-size: 28rpx;
  font-weight: 800;
  word-break: break-all;
}

.project-chip {
  display: inline-flex;
  max-width: 100%;
  overflow: hidden;
  margin-top: 10rpx;
  border-radius: 18rpx;
  background: #EEF5FF;
  padding: 6rpx 14rpx;
  color: #0B57D0;
  font-size: 22rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-content {
  margin-top: 10rpx;
  color: #424242;
  font-size: 26rpx;
  line-height: 1.55;
  overflow-wrap: break-word;
  word-break: break-all;
}

.log-meta {
  display: inline-flex;
  margin-top: 14rpx;
  border-radius: 18rpx;
  background: #EEF5FF;
  padding: 6rpx 14rpx;
  color: #0B57D0;
  font-size: 22rpx;
  font-weight: 800;
}

.analysis {
  margin-top: 14rpx;
  border-radius: 16rpx;
  background: #ECFDF9;
  padding: 16rpx;
  color: #0F766E;
  font-size: 23rpx;
  line-height: 1.5;
}

.analysis-risk {
  margin-top: 8rpx;
  color: #EE3B2B;
}

.missing-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.missing-item {
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  border-radius: 16rpx;
  background: #F6F6F6;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
}

.missing-item text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.missing-item text:first-child {
  flex: 1 1 0;
}

.missing-item text:last-child {
  flex: 0 1 45%;
  text-align: right;
}
