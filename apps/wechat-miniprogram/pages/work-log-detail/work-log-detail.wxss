.detail-header {
  padding: 12rpx 4rpx 22rpx;
}

.detail-date {
  color: #0F766E;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-title {
  margin-top: 8rpx;
  color: #1A1A1A;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
  word-break: break-all;
}

.detail-subtitle {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
  color: #737373;
  font-size: 24rpx;
}

.detail-subtitle text {
  border-radius: 18rpx;
  background: #F6F6F6;
  padding: 6rpx 14rpx;
}

.detail-section,
.ai-detail-section {
  margin-top: 20rpx;
  padding: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border-top: 1rpx solid #E6E6E6;
  padding-top: 20rpx;
  margin-top: 20rpx;
  color: #424242;
  font-size: 26rpx;
  line-height: 1.45;
}

.info-row text:first-child {
  flex-shrink: 0;
  color: #737373;
}

.info-row text:last-child {
  min-width: 0;
  text-align: right;
  word-break: break-all;
}

.content-text {
  margin-top: 14rpx;
  color: #424242;
  font-size: 28rpx;
  line-height: 1.62;
  word-break: break-all;
}

.ai-detail-section {
  border-color: #CCFBF1;
  background: #ECFDF9;
}

.ai-kicker {
  color: #0F766E;
  font-size: 24rpx;
  font-weight: 900;
}

.ai-summary {
  margin-top: 12rpx;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.5;
}

.analysis-block {
  margin-top: 18rpx;
}

.analysis-title {
  color: #0F766E;
  font-size: 23rpx;
  font-weight: 900;
}

.analysis-title.danger,
.analysis-line.danger {
  color: #EE3B2B;
}

.analysis-title.warning,
.analysis-line.warning {
  color: #D97706;
}

.analysis-line {
  margin-top: 8rpx;
  color: #424242;
  font-size: 25rpx;
  line-height: 1.48;
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.keyword-row text {
  max-width: 100%;
  overflow: hidden;
  border-radius: 18rpx;
  background: #FFFFFF;
  padding: 6rpx 14rpx;
  color: #0F766E;
  font-size: 22rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 16rpx;
  background: #F6F6F6;
  padding: 18rpx 20rpx;
}

.attachment-item > view:first-child {
  min-width: 0;
  flex: 1 1 0;
}

.attachment-name {
  overflow: hidden;
  color: #1A1A1A;
  font-size: 25rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-meta {
  margin-top: 5rpx;
  color: #737373;
  font-size: 22rpx;
}

.attachment-action {
  flex-shrink: 0;
  color: #0B57D0;
  font-size: 24rpx;
  font-weight: 800;
}

.loading {
  margin-top: 20rpx;
  color: #737373;
  font-size: 24rpx;
  text-align: center;
}
