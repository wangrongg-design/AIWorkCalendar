.login-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: flex-start;
  gap: 0;
  padding-top: 76rpx;
  background: #1A1A1A;
}

.login-brand {
  flex: 0 0 auto;
  padding-top: 46rpx;
}

.brand-logo-wrap {
  display: flex;
  width: 172rpx;
  height: 56rpx;
  align-items: center;
  justify-content: flex-start;
}

.brand-logo {
  width: 172rpx;
  height: 56rpx;
  opacity: 0.95;
}

.brand-product {
  margin-top: 78rpx;
  color: #A3A3A3;
  font-size: 33rpx;
  font-weight: 700;
  line-height: 1.3;
}

.brand-title {
  max-width: 100%;
  margin-top: 18rpx;
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.12;
  overflow-wrap: break-word;
}

.login-form {
  display: flex;
  flex-direction: column;
  flex: 0 0 auto;
  gap: 26rpx;
  margin-top: 146rpx;
}

.login-form .field {
  margin-top: 0;
}

.login-form .field-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  font-weight: 700;
}

.login-agreement {
  flex: 0 0 auto;
  margin-top: 2rpx;
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 0;
}

.agreement-check {
  position: relative;
  width: 26rpx;
  height: 26rpx;
  flex: 0 0 26rpx;
  border: 2rpx solid #737373;
  border-radius: 50%;
}

.agreement-check.checked {
  border-color: #0B57D0;
  background: #0B57D0;
}

.agreement-check.checked::after {
  position: absolute;
  left: 7rpx;
  top: 5rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 3rpx solid #FFFFFF;
  border-bottom: 3rpx solid #FFFFFF;
  content: "";
  transform: rotate(-45deg);
}

.agreement-copy {
  display: flex;
  min-width: 0;
  flex: 1 1 0;
  flex-wrap: nowrap;
  align-items: center;
  color: rgba(255, 255, 255, 0.68);
  font-size: 18rpx;
  line-height: 1.45;
  overflow: hidden;
  white-space: nowrap;
}

.agreement-link {
  width: auto;
  min-width: auto;
  flex: 0 0 auto;
  height: auto;
  display: inline-flex;
  background: transparent;
  color: #7BAAF7;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.45;
  padding: 0;
}

.agreement-link::after {
  border: 0;
}

.privacy-note {
  margin-top: 12rpx;
  padding-left: 34rpx;
  color: rgba(255, 255, 255, 0.42);
  font-size: 20rpx;
  line-height: 1.45;
}

.login-input,
.password-row {
  border: 1rpx solid #424242;
  border-radius: 22rpx;
  background: #2B2B2B;
}

.login-input {
  color: #FFFFFF;
}

.password-row {
  display: flex;
  align-items: center;
}

.password-input {
  flex: 1 1 0;
  border: 0 !important;
  background: transparent !important;
  color: #FFFFFF;
}

.password-toggle {
  position: relative;
  width: 88rpx;
  flex: 0 0 88rpx;
  height: 88rpx;
  min-width: 88rpx;
  border: 0 !important;
  border-radius: 18rpx;
  background: transparent !important;
  color: rgba(255, 255, 255, 0.58);
  line-height: 88rpx;
  padding: 0;
}

.password-toggle::after {
  border: 0;
}

.password-toggle.button-hover {
  background: transparent !important;
}

.visibility-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  color: rgba(255, 255, 255, 0.58);
}

.visibility-icon.shown {
  color: rgba(255, 255, 255, 0.84);
}

.visibility-eye {
  position: absolute;
  left: 3rpx;
  right: 3rpx;
  top: 11rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 50% / 58%;
}

.visibility-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  transform: translate(-50%, -50%);
}

.visibility-lid {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  top: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: scaleX(0);
  transform-origin: center;
}

.visibility-icon.hidden .visibility-dot {
  opacity: 0.22;
}

.visibility-icon.hidden .visibility-lid {
  transform: rotate(-35deg) scaleX(1);
}

.login-button {
  height: 88rpx;
  width: 100%;
  margin-top: 16rpx;
  border: 1rpx solid #424242;
  border-radius: 22rpx;
  background: #2B2B2B;
  color: #A3A3A3;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.login-button.enabled {
  border-color: #0B57D0;
  background: #0B57D0;
  color: #FFFFFF;
}

.login-button[disabled] {
  border-color: #424242 !important;
  background: #2B2B2B !important;
  color: #A3A3A3 !important;
  opacity: 1;
}

.login-footer {
  display: flex;
  flex-direction: column;
  flex: 1 0 auto;
  gap: 6rpx;
  justify-content: flex-end;
  min-height: 156rpx;
  padding-bottom: 4rpx;
}

.login-footer view:first-child {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.login-footer view:last-child {
  color: rgba(255, 255, 255, 0.42);
  font-size: 22rpx;
  line-height: 1.4;
}

@media (max-height: 700px) {
  .login-page {
    padding-top: 52rpx;
  }

  .login-brand {
    padding-top: 28rpx;
  }

  .brand-product {
    margin-top: 52rpx;
  }

  .login-form {
    margin-top: 88rpx;
  }

  .login-footer {
    min-height: 112rpx;
  }
}
