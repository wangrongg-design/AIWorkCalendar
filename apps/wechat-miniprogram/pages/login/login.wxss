.login-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: flex-start;
  gap: 24rpx;
  padding-top: 48rpx;
  background: #1A1A1A;
}

.login-hero {
  padding: 0 4rpx 10rpx;
}

.brand-logo-wrap {
  display: flex;
  width: 132rpx;
  height: 48rpx;
  align-items: center;
  justify-content: flex-start;
}

.brand-logo {
  width: 132rpx;
  height: 48rpx;
  opacity: 0.94;
}

.brand-product {
  margin-top: 54rpx;
  color: #A3A3A3;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.brand-title {
  margin-top: 14rpx;
  color: #FFFFFF;
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1.15;
}

.brand-subtitle {
  margin-top: 28rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.brand-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.42);
  font-size: 26rpx;
  line-height: 1.45;
}

.login-card {
  border-color: rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
  padding: 34rpx;
  box-shadow: none;
}

.login-card .section-title {
  color: #FFFFFF;
}

.login-card .section-desc,
.login-card .field-label {
  color: rgba(255, 255, 255, 0.7);
}

.login-card .chip {
  background: rgba(255, 255, 255, 0.1);
  color: #CCFBF1;
}

.login-card .input {
  border-color: rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08);
  color: #FFFFFF;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 8rpx;
}

.card-head > view:first-child {
  min-width: 0;
}

.card-head .chip {
  flex-shrink: 0;
}

.login-button {
  margin-top: 34rpx;
}

.password-row {
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.password-input {
  flex: 1 1 0;
  border: 0 !important;
  background: transparent !important;
}

.password-toggle {
  flex: 0 0 104rpx;
  height: 88rpx;
  color: #A3A3A3;
  font-size: 24rpx;
  line-height: 88rpx;
}

.notice-card {
  border-color: rgba(255, 255, 255, 0.12);
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  box-shadow: none;
}

.notice-title {
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
  font-weight: 800;
}

.notice {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.46);
  font-size: 23rpx;
  line-height: 1.55;
}
