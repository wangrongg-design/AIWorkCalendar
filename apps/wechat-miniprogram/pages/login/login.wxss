.login-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: space-between;
  gap: 56rpx;
  padding-top: 56rpx;
  background: #1F1F1F;
}

.login-brand {
  padding-top: 24rpx;
}

.brand-logo-wrap {
  display: flex;
  width: 172rpx;
  height: 56rpx;
  align-items: center;
  justify-content: flex-start;
}

.brand-logo {
  width: 172rpx;
  height: 56rpx;
  opacity: 0.95;
}

.brand-product {
  margin-top: 64rpx;
  color: #A3A3A3;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.brand-title {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 62rpx;
  font-weight: 900;
  line-height: 1.14;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.login-form .field {
  margin-top: 0;
}

.login-form .field-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  font-weight: 700;
}

.login-input,
.password-row {
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.login-input {
  color: #FFFFFF;
}

.password-row {
  display: flex;
  align-items: center;
}

.password-input {
  flex: 1 1 0;
  border: 0 !important;
  background: transparent !important;
  color: #FFFFFF;
}

.password-toggle {
  flex: 0 0 104rpx;
  height: 88rpx;
  color: #A3A3A3;
  font-size: 24rpx;
  line-height: 88rpx;
}

.login-button {
  margin-top: 6rpx;
}

.login-footer {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 4rpx;
}

.login-footer view:first-child {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.login-footer view:last-child {
  color: rgba(255, 255, 255, 0.42);
  font-size: 22rpx;
  line-height: 1.4;
}
