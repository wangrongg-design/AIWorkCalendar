.login-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: space-between;
  gap: 56rpx;
  padding-top: 56rpx;
  background: #1A1A1A;
}

.login-brand {
  padding-top: 24rpx;
}

.brand-logo-wrap {
  display: flex;
  width: 172rpx;
  height: 56rpx;
  align-items: center;
  justify-content: flex-start;
}

.brand-logo {
  width: 172rpx;
  height: 56rpx;
  opacity: 0.95;
}

.brand-product {
  margin-top: 64rpx;
  color: #A3A3A3;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.brand-title {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 62rpx;
  font-weight: 900;
  line-height: 1.14;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.login-form .field {
  margin-top: 0;
}

.login-form .field-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  font-weight: 700;
}

.login-input,
.password-row {
  border: 1rpx solid #424242;
  border-radius: 24rpx;
  background: #2E2E2E;
}

.login-input {
  color: #FFFFFF;
}

.password-row {
  display: flex;
  align-items: center;
}

.password-input {
  flex: 1 1 0;
  border: 0 !important;
  background: transparent !important;
  color: #FFFFFF;
}

.password-toggle {
  position: relative;
  width: 88rpx;
  flex: 0 0 88rpx;
  height: 88rpx;
  min-width: 88rpx;
  border: 0 !important;
  border-radius: 18rpx;
  background: transparent !important;
  color: rgba(255, 255, 255, 0.58);
  line-height: 88rpx;
  padding: 0;
}

.password-toggle::after {
  border: 0;
}

.password-toggle.button-hover {
  background: transparent !important;
}

.visibility-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  color: rgba(255, 255, 255, 0.58);
}

.visibility-icon.shown {
  color: rgba(255, 255, 255, 0.84);
}

.visibility-eye {
  position: absolute;
  left: 3rpx;
  right: 3rpx;
  top: 11rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 50% / 58%;
}

.visibility-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  transform: translate(-50%, -50%);
}

.visibility-lid {
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  top: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: scaleX(0);
  transform-origin: center;
}

.visibility-icon.hidden .visibility-eye {
  height: 0;
  top: 21rpx;
  border-top: 4rpx solid currentColor;
  border-right: 0;
  border-bottom: 0;
  border-left: 0;
  border-radius: 999rpx;
}

.visibility-icon.hidden .visibility-dot {
  opacity: 0;
}

.visibility-icon.hidden .visibility-lid {
  transform: scaleX(1);
}

.login-button {
  height: 88rpx;
  margin-top: 6rpx;
  border: 1rpx solid #424242;
  border-radius: 24rpx;
  background: #2E2E2E;
  color: #A3A3A3;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.login-button.enabled {
  border-color: #0B57D0;
  background: #0B57D0;
  color: #FFFFFF;
}

.login-button[disabled] {
  border-color: #424242 !important;
  background: #2E2E2E !important;
  color: #A3A3A3 !important;
  opacity: 1;
}

.login-footer {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 4rpx;
}

.login-footer view:first-child {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.login-footer view:last-child {
  color: rgba(255, 255, 255, 0.42);
  font-size: 22rpx;
  line-height: 1.4;
}
