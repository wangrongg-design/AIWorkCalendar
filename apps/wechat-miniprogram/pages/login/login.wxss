.login-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: space-between;
  gap: 56rpx;
  padding-top: 56rpx;
  background: #1A1A1A;
}

.login-brand {
  padding-top: 24rpx;
}

.brand-logo-wrap {
  display: flex;
  width: 172rpx;
  height: 56rpx;
  align-items: center;
  justify-content: flex-start;
}

.brand-logo {
  width: 172rpx;
  height: 56rpx;
  opacity: 0.95;
}

.brand-product {
  margin-top: 64rpx;
  color: #A3A3A3;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.brand-title {
  margin-top: 16rpx;
  color: #FFFFFF;
  font-size: 62rpx;
  font-weight: 900;
  line-height: 1.14;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.login-form .field {
  margin-top: 0;
}

.login-form .field-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  font-weight: 700;
}

.login-input,
.password-row {
  border: 1rpx solid #424242;
  border-radius: 24rpx;
  background: #2E2E2E;
}

.login-input {
  color: #FFFFFF;
}

.password-row {
  display: flex;
  align-items: center;
}

.password-input {
  flex: 1 1 0;
  border: 0 !important;
  background: transparent !important;
  color: #FFFFFF;
}

.password-toggle {
  position: relative;
  flex: 0 0 88rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.eye-icon {
  position: relative;
  width: 40rpx;
  height: 26rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.52);
  border-radius: 50%;
  transform: rotate(-8deg);
}

.eye-icon.visible {
  border-color: rgba(255, 255, 255, 0.72);
}

.eye-pupil {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.62);
  transform: translate(-50%, -50%);
}

.eye-icon.visible .eye-pupil {
  background: #FFFFFF;
}

.eye-slash {
  position: absolute;
  left: 18rpx;
  top: -11rpx;
  width: 4rpx;
  height: 48rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.62);
  transform: rotate(52deg);
}

.login-button {
  height: 88rpx;
  margin-top: 6rpx;
  border: 1rpx solid #424242;
  border-radius: 24rpx;
  background: #2E2E2E;
  color: #A3A3A3;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.login-button.enabled {
  border-color: #0B57D0;
  background: #0B57D0;
  color: #FFFFFF;
}

.login-button[disabled] {
  opacity: 1;
}

.login-footer {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 4rpx;
}

.login-footer view:first-child {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.login-footer view:last-child {
  color: rgba(255, 255, 255, 0.42);
  font-size: 22rpx;
  line-height: 1.4;
}
