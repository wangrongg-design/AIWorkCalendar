<view class="page login-page bottom-safe">
  <view class="login-hero">
    <view class="brand-logo-wrap">
      <image class="brand-logo" src="/assets/seven-ai-logo.png" mode="aspectFit" />
    </view>
    <view class="brand-title">Work Calendar AI</view>
    <view class="brand-subtitle">北京七数智联科技有限公司</view>
    <view class="brand-desc">移动端快速填报 · 日历看板 · AI 汇报</view>
  </view>

  <view class="surface login-card">
    <view class="card-head">
      <view>
        <view class="section-title">登录企业账号</view>
        <view class="section-desc">使用 PC 端同一账号，移动端只保留高频操作。</view>
      </view>
      <view class="chip">安全连接</view>
    </view>

    <view class="field">
      <text class="field-label">API 地址</text>
      <input class="input" value="{{apiBaseUrl}}" placeholder="https://api.example.com" bindinput="onApiBaseUrlInput" />
    </view>

    <view class="field">
      <text class="field-label">企业代码</text>
      <input class="input" value="{{tenantCode}}" placeholder="demo" bindinput="onTenantCodeInput" />
    </view>

    <view class="field">
      <text class="field-label">邮箱</text>
      <input class="input" value="{{email}}" placeholder="admin@example.com" bindinput="onEmailInput" />
    </view>

    <view class="field">
      <text class="field-label">密码</text>
      <input class="input" password value="{{password}}" placeholder="Passw0rd!" bindinput="onPasswordInput" />
    </view>

    <button class="primary-button login-button" loading="{{loading}}" bindtap="login">登录</button>
  </view>

  <view class="surface notice-card">
    <view class="notice-title">本地调试</view>
    <view class="notice">
      微信开发者工具需关闭“校验合法域名”。生产环境请使用 HTTPS API 域名。
    </view>
  </view>
</view>
