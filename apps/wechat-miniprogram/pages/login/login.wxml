<view class="page login-page bottom-safe">
  <view class="login-brand">
    <view class="brand-logo-wrap">
      <image class="brand-logo" src="/assets/seven-ai-logo.png" mode="aspectFit" />
    </view>
    <view class="brand-product">AIWorkCalendar</view>
    <view class="brand-title">开启你的AI之旅</view>
  </view>

  <view class="login-form">
    <view class="field">
      <text class="field-label">邮箱或手机号</text>
      <input class="input login-input" value="{{account}}" placeholder="请输入邮箱或手机号" bindinput="onAccountInput" />
    </view>

    <view class="field">
      <text class="field-label">密码</text>
      <view class="password-row">
        <input class="input password-input" password="{{!showPassword}}" value="{{password}}" placeholder="请输入密码" bindinput="onPasswordInput" />
        <button class="password-toggle {{showPassword ? 'active' : ''}}" aria-label="{{showPassword ? '隐藏密码' : '显示密码'}}" bindtap="togglePassword">
          <view class="visibility-icon {{showPassword ? 'shown' : 'hidden'}}">
            <view class="visibility-eye"></view>
            <view class="visibility-dot"></view>
            <view class="visibility-lid"></view>
          </view>
        </button>
      </view>
    </view>

    <button
      class="login-button {{canLogin ? 'enabled' : ''}}"
      loading="{{loading}}"
      disabled="{{!canLogin || loading}}"
      bindtap="login"
    >
      登录
    </button>

    <view class="login-agreement">
      <view class="agreement-row" bindtap="toggleAgreement">
        <view class="agreement-check {{hasAgreed ? 'checked' : ''}}"></view>
        <view class="agreement-copy">
          <text>我已阅读并同意</text>
          <button class="agreement-link" catchtap="showUserAgreement">《用户服务协议》</button>
          <text>和</text>
          <button class="agreement-link" catchtap="openPrivacyContract">《隐私政策》</button>
        </view>
      </view>
      <view class="privacy-note">邮箱或手机号仅用于账号登录、企业身份校验、日报归属和账号安全。</view>
    </view>
  </view>

  <view class="login-footer">
    <view>北京七数智联科技有限公司</view>
    <view>企业级 AI 工作填报与智能汇报 SaaS</view>
  </view>
</view>
