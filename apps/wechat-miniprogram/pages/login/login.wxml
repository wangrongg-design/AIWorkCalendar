<view class="page login-page bottom-safe">
  <view class="login-brand">
    <view class="brand-logo-wrap">
      <image class="brand-logo" src="/assets/seven-ai-logo.png" mode="aspectFit" />
    </view>
    <view class="brand-product">AIWorkCalendar</view>
    <view class="brand-title">开启你的AI之旅</view>
  </view>

  <view class="login-form">
    <view class="field">
      <text class="field-label">邮箱或手机号</text>
      <input class="input login-input" value="{{account}}" placeholder="请输入邮箱或手机号" bindinput="onAccountInput" />
    </view>

    <view class="field">
      <text class="field-label">密码</text>
      <view class="password-row">
        <input class="input password-input" password="{{!showPassword}}" value="{{password}}" placeholder="请输入密码" bindinput="onPasswordInput" />
        <button class="password-toggle" aria-label="{{showPassword ? '隐藏密码' : '显示密码'}}" bindtap="togglePassword">
          <view class="eye-icon {{showPassword ? 'visible' : ''}}">
            <view class="eye-pupil"></view>
            <view wx:if="{{!showPassword}}" class="eye-slash"></view>
          </view>
        </button>
      </view>
    </view>

    <button class="primary-button login-button" loading="{{loading}}" bindtap="login">登录</button>
  </view>

  <view class="login-footer">
    <view>北京七数智联科技有限公司</view>
    <view>企业级 AI 工作填报与智能汇报 SaaS</view>
  </view>
</view>
